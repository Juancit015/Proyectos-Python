#Funciones
def enviar_reporte(ALERTA_DE_SEGURIDAD):
    remitente = ""
    password = ""
    receptor = ""
    
    asunto = "Alerta de seguridad!"
    #Cuerpo del gmail
    email_cuerpo = f"subject: {asunto}\n\n{ALERTA_DE_SEGURIDAD}"
    #Intenta validar las credenciales y envia el gmail 
    try:
        #Establesco conexion usando la libreria para conectarse con el servidor de google y el puerto 465 siendo el seguro
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        #Me logueo con el dato remitente y password
        server.login(remitente , password)
        #Envio el email primero remitente luego el receptor y el cuerpo del email
        server.sendmail(remitente ,receptor, email_cuerpo)
        #Cierro la llamada al servidor
        server.quit()
        print("!Reporte enviado de manera excitosa")
    except Exception as e:
        #Si no se logro dime el por que
        print(f"Error: {e}")

